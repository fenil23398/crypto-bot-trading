# MongoDB Atlas free tier — paste your connection string here
# Sign up at https://cloud.mongodb.com (free M0 cluster)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/trading-bot?retryWrites=true&w=majority

NODE_ENV=development
LOG_LEVEL=info

# Binance public API (no auth needed)
BINANCE_BASE_URL=https://data-api.binance.vision

# Sync config
SYNC_CRON=0 */1 * * *
BACKFILL_DAYS=30

# API server
PORT=3000

# SuperTrend settings
SUPERTREND_PERIOD=10
SUPERTREND_MULTIPLIER=3

# MACD settings
MACD_FAST_PERIOD=12
MACD_SLOW_PERIOD=26
MACD_SIGNAL_PERIOD=9

# RSI + EMA settings
RSI_PERIOD=14
EMA_PERIOD=200
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70

# MA9 (9-period SMA cross) — price cross above = BUY, below = SELL
MA9_PERIOD=9
MA9_TYPE=sma

# RSI 60/40 — cross above buyThreshold = BUY, cross below sellThreshold = SELL (short)
RSI_LEVELS_PERIOD=14
RSI_LEVELS_BUY=60
RSI_LEVELS_SELL=40

# ADX trend filter (applies to all strategy bots + backtest when enabled)
# Set ADX_FILTER_ENABLED=false to disable
ADX_FILTER_ENABLED=true
ADX_PERIOD=14
ADX_THRESHOLD=25

# ASTER Dex — create keys at https://www.asterdex.com/en/api-management
ASTER_API_KEY=your_api_key
ASTER_SECRET_KEY=your_secret_key
ASTER_BASE_URL=https://fapi.asterdex.com
ASTER_LEVERAGE=3
ASTER_TRADE_USDT=100
ASTER_SL_PERCENT=25
ASTER_TP_PERCENT=25
