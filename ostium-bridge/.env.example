# Ostium Python SDK — same variables as upstream docs (see https://ostium-labs.gitbook.io/ostium-docs/developer/api-and-sdk)
OSTIUM_NETWORK=testnet
# Arbitrum RPC (Alchemy, Infura, etc.)
RPC_URL=https://arb-sepolia.g.alchemy.com/v2/your-key
# Wallet that signs trades (keep secret; only this service should see it)
PRIVATE_KEY=0x...

# Optional: shared secret; Node backend must send the same value in X-Ostium-Bridge-Secret
OSTIUM_BRIDGE_SECRET=

# Slippage % for market open/close (SDK default pattern)
OSTIUM_SLIPPAGE_PERCENT=1

# Optional JSON map when Ostium quote asset does not match Binance symbol suffix, e.g. {"BTCUSDT":"0","ETHUSDT":"1"}
OSTIUM_PAIR_MAP={}
